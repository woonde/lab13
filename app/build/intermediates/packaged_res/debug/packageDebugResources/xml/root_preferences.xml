<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="Профиль игрока">

        <EditTextPreference
            app:key="player_name"
            app:title="Имя игрока"
            app:summary="Введите ваше имя"
            app:defaultValue="Игрок"
            app:dialogTitle="Имя игрока"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory app:title="Игровые параметры">

        <ListPreference
            app:key="difficulty"
            app:title="Сложность"
            app:dialogTitle="Выберите сложность"
            app:entries="@array/difficulty_entries"
            app:entryValues="@array/difficulty_values"
            app:defaultValue="medium"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            app:key="sound_enabled"
            app:title="Звук"
            app:summary="Звуковой сигнал при ходе"
            app:defaultValue="true" />

        <SwitchPreferenceCompat
            app:key="player_starts"
            app:title="Игрок ходит первым"
            app:summary="Если выключено — первым ходит компьютер"
            app:defaultValue="true" />

    </PreferenceCategory>

</PreferenceScreen>